# --- Bridge server ---
PORT=3001

# --- Reader defaults (can be overridden per /connect request) ---
UR4_IP=192.168.99.202
UR4_PORT=8888

# --- Chainway CP30 printer defaults (also configurable live via /printer/config) ---
# PRINTER_TRANSPORT=usb            # usb (Windows queue, RAW) | tcp (raw port 9100)
# PRINTER_NAME=Chainway CP30       # Windows print queue name (usb transport)
# PRINTER_HOST=192.168.99.201      # printer IP (tcp transport)
# PRINTER_TCP_PORT=9100

# --- Optional Supabase forwarding ---
# If SUPABASE_URL and SUPABASE_ANON_KEY are both set, each tag read is POSTed
# to the REST table below. Leave blank to disable forwarding.
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_TABLE=rfid_reads
