<?xml version="1.0" encoding="utf-8"?>
<!--
  Launcher icon mark: the RFID radio-waves glyph (same Lucide "radio" used on the
  Reader status chip), layered in brand colors — green tag dot, blue inner waves,
  grey outer waves. Drawn in a 24x24 space, scaled into the adaptive-icon safe zone.
-->
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    android:width="108dp"
    android:height="108dp"
    android:viewportWidth="108"
    android:viewportHeight="108">
    <group
        android:scaleX="2.3"
        android:scaleY="2.3"
        android:translateX="26.4"
        android:translateY="26.4">
        <!-- outer waves -->
        <path
            android:pathData="M4.9,19.1 C1,15.2 1,8.8 4.9,4.9"
            android:strokeColor="#6B7683"
            android:strokeWidth="2"
            android:strokeLineCap="round" />
        <path
            android:pathData="M19.1,4.9 C23,8.8 23,15.2 19.1,19.1"
            android:strokeColor="#6B7683"
            android:strokeWidth="2"
            android:strokeLineCap="round" />
        <!-- inner waves -->
        <path
            android:pathData="M7.8,16.2 c-2.3,-2.3 -2.3,-6.1 0,-8.5"
            android:strokeColor="#1F6FEB"
            android:strokeWidth="2"
            android:strokeLineCap="round" />
        <path
            android:pathData="M16.2,7.8 c2.3,2.3 2.3,6.1 0,8.5"
            android:strokeColor="#1F6FEB"
            android:strokeWidth="2"
            android:strokeLineCap="round" />
        <!-- tag dot -->
        <path
            android:pathData="M12,12 m-2.4,0 a2.4,2.4 0,1,1 4.8,0 a2.4,2.4 0,1,1 -4.8,0"
            android:fillColor="#2EA043" />
    </group>
</vector>
